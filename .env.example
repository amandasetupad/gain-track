# Frontend (Vite) — set in Vercel or create .env locally
# In dev, the Vite proxy uses /api so this can be left unset.
# In production, set to your Render (or other) backend URL — must be HTTPS.
VITE_API_URL=https://your-app-api.onrender.com

# Backend (Express) — set in Render dashboard
# Optional: PostgreSQL connection string (e.g. from Render PostgreSQL). If set, data persists across restarts.
# DATABASE_URL=postgresql://user:pass@host/dbname
# Comma-separated list of allowed frontend origins (your Vercel URL).
CORS_ORIGIN=https://your-workout-site.vercel.app
# Optional: use a strong secret in production
JWT_SECRET=your-secret-here
